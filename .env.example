# Frontend
REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENV=development

# Backend
NODE_ENV=development
PORT=5000
DATABASE_URL=sqlite:./database/basketball.db
API_KEY_ESPN=your_espn_api_key
API_KEY_NBA_STATS=your_nba_stats_key
API_KEY_ODDS=your_odds_api_key

# Python Analytics
PYTHON_ENV=development
PYTHON_PORT=5001
DB_PATH=./database/basketball.db

# Betting Config
DEFAULT_BANKROLL=1000
KELLY_FRACTION=0.25
MIN_EV_THRESHOLD=0.05

# League IDs
NBA_LEAGUE_ID=nba
GBL_LEAGUE_ID=gbl
ELITE_LEAGUE_ID=elite
